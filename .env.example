# Dead Drop Channel Credentials
# Get Imgur Client ID at: https://api.imgur.com/oauth2/addclient
IMGUR_CLIENT_ID=your_imgur_client_id_here

# Get GitHub token at: https://github.com/settings/tokens
# Required scopes: gist (read and write)
GITHUB_TOKEN=your_github_token_here

# Redis (do not change — matches docker-compose service name)
REDIS_URL=redis://redis:6379

# Backend
NODE_ENV=production
PORT=4000

# Frontend (build time — Vite injects these)
VITE_API_URL=http://localhost:3000/api
